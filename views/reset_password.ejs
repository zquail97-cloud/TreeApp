<!-- EJS template for the reset password page. This page allows users to reset their password after receiving a reset link via email. --> 
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Reset Password – TreeApp</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div class="auth-form-container">
    <div class="auth-form">
      <h2>Reset your password</h2>
      <p>Enter a new password below to reset your account.</p>

      <% if (error) { %>
        <!-- Display error message if there is an error -->
        <div class="error-message"><%= error %></div>
      <% } %>

      <!-- Display success message if the password was reset successfully -->
      <% if (success) { %>
        <div class="success-message"><%= success %></div>
      <% } %>

      <!-- Form to reset the password -->
      <form method="POST">
        <input type="password" name="new_password" placeholder="New password" required />
        <input type="password" name="confirm_password" placeholder="Confirm password" required />
        <button type="submit" class="green-button">🔐 Reset Password</button>
      </form>

      <!-- Link to go back to the login page -->
      <a href="/auth/login" class="back-link">← Back to login</a>
    </div>
  </div>
</body>
</html>

