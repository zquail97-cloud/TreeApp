    async function renderMap() {
      clearAllMarkers();
      if (heatLayer) map.removeLayer(heatLayer);

      const mode = document.getElementById('displayMode').value;
      const selectedDataType = document.getElementById('dataType').value;
      const speciesId = document.getElementById('filterSpecies').value;
      const conditionId = document.getElementById('filterCondition').value;
      const startDate = document.getElementById('filterStartDate').value;
      const endDate = document.getElementById('filterEndDate').value;
      currentDisplayMode = mode;

      try {
        if (mode === 'heatmap') {
          let url = new URL(`${window.location.origin}/api/trees/heatmap/${selectedDataType}`);
          if (speciesId) url.searchParams.append('species_id', speciesId);
          if (conditionId) url.searchParams.append('condition_id', conditionId);

          const res = await fetch(url);
          const data = await res.json();
          const heatPoints = data.map(p => [parseFloat(p.latitude), parseFloat(p.longitude), 0.7]);
          heatLayer = L.heatLayer(heatPoints, { radius: 25, blur: 20, maxZoom: 17, gradient: { 0.2: 'red', 0.5: 'yellow', 1.0: 'green' }, max: 0.8 }).addTo(map);
        } else { // mode === 'markers'
          let url = new URL(`${window.location.origin}/api/trees/search`);
          if (speciesId) url.searchParams.append('species_id', speciesId);
          if (conditionId) url.searchParams.append('condition_id', conditionId);
          if (startDate) url.searchParams.append('startDate', startDate);
          if (endDate) url.searchParams.append('endDate', endDate);
          if (selectedDataType === 'updates') url.searchParams.append('has_pending_updates', 'true');
          //Ads latitude and longitude for proximity sorting
          if (userLat && userLng) {
            url.searchParams.append('latitude', userLat);
            url.searchParams.append('longitude', userLng);
          }

          const res = await fetch(url);
          const trees = await res.json();

          lastFetchedTrees = trees;
          updateSummaryStats(trees);
          addMarkersThematically(trees, selectedDataType);
        }
      } catch (err) {
        console.error('Failed to render map view:', err);
      }
    }

