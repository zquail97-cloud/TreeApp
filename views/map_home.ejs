            if (viewDetailsBtn) {
                fetchAndShowTreeDetails(viewDetailsBtn.dataset.treeId);
                return; // Stop further checks
            }

            // - Handlers for buttons inside the Details Overlay 
            const verifyBtn = e.target.closest('.verify-tree-btn');
            if (verifyBtn) {
                const treeId = verifyBtn.dataset.treeId;
                fetch(`/api/trees/${treeId}/verify`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                })
                .then(res => res.json())
                .then(data => {
                    alert(data.message || 'Tree verified!');
                    document.getElementById('treeDetailsOverlay').classList.remove('show');
                    fetchNearbyTrees();
                })
                .catch(err => console.error('Verification failed:', err));
                return;
            }
            
            const editBtn = e.target.closest('.edit-tree-btn');
            if (editBtn) {
                // Populates the main public submission form for editing
                enterEditMode(editBtn.dataset.treeId);
                return;
            }

            const deleteBtn = e.target.closest('.delete-tree-btn');
            if (deleteBtn) {
                const treeId = deleteBtn.dataset.treeId;
                if (confirm('Are you sure you want to delete this tree? This action cannot be undone.')) {
                    fetch(`/api/trees/${treeId}`, { method: 'DELETE' })
                    .then(res => res.json())
                    .then(data => {
                        alert('Tree deleted successfully.');
                        document.getElementById('treeDetailsOverlay').classList.remove('show');
                        fetchNearbyTrees(); // Refresh map
                    })
                    .catch(err => console.error('Delete failed:', err));
                }
                return;
            }

            const suggestBtn = e.target.closest('.suggest-update-btn');
            if (suggestBtn) {
                document.getElementById('suggestTreeId').value = suggestBtn.dataset.treeId;
                document.getElementById('suggestOverlay').style.display = 'flex';
                return;
            }

            const compareBtn = e.target.closest('.compare-update-btn');
            if (compareBtn) {
                openCompareUpdatePanel(compareBtn.dataset.treeId);
                return;
            }

             const thumbnail = e.target.closest('.tree-popup-thumbnail');
              if (thumbnail) {
                  const imageModal = document.getElementById('imageViewerModal');
                  const fullImage = document.getElementById('fullImage');
                  
                  fullImage.src = thumbnail.dataset.fullSrc; // Get URL from data attribute
                  imageModal.style.display = 'flex'; // Use 'flex' to center the image
                  return; // Stop further checks
              }

            //  Handler for ".vote-btn" in the Compare Panel 
            const voteBtn = e.target.closest('.vote-btn');
            if (voteBtn) {
                const updateId = voteBtn.dataset.updateId;
                const voteType = voteBtn.dataset.vote;
                try {
                    const res = await fetch(`/api/updates/${updateId}/vote`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ vote: voteType })
                    });
                    const response = await res.json();
                    alert(`Thank you for your ${voteType === 'up' ? 'upvote' : 'downvote'}!`);
                    document.getElementById('comparePanel').classList.remove('show');
                } catch (err) {
                    console.error('Vote error:', err);
                }
                return;
            }

            //  Handlers for buttons in Sidebar Notifications 
            const zoomBtn = e.target.closest('.zoom-to-tree-btn');
            if (zoomBtn) {
                const treeId = zoomBtn.dataset.treeId;
                const marker = currentMarkers.find(m => m.options.treeId == treeId);
                if (marker) {
                    map.setView(marker.getLatLng(), 18, { animate: true });
                    marker.openPopup();
                } else {
                    console.warn('Marker not found for tree:', treeId);
                }
                return;
            }

            const dismissBtn = e.target.closest('.dismiss-btn');
            if (dismissBtn) {
                const listItem = dismissBtn.closest('.notification-item');
                const notifId = listItem?.dataset.id;
                if (notifId) {
                    try {
                        const res = await fetch(`/api/notifications/${notifId}/read`, { method: 'POST' });
                        if (res.ok) listItem.remove();
                    } catch (err) {
                        console.error('Error marking notification as read:', err);
                    }
                }
                return;
            }
        });


    // --------------------------------------------------------------------------------- Location Tracking ---------------------------------------------------------------------------------

    let locationWatchId = null;
    function startLiveLocationTracking() {
            if (locationWatchId !== null) return; // Prevent multiple watchers

            if (!navigator.geolocation) {
                console.warn('Geolocation is not supported by this browser.');
                // As a fallback, fetch trees for a default Belfast location
                fetchNearbyTrees();
                return;
            }

            locationWatchId = navigator.geolocation.watchPosition(
                (position) => {
                    const newLat = position.coords.latitude;
                    const newLng = position.coords.longitude;

                    // Only update if the user has moved a meaningful distance
                    const hasMoved = !userLat || !userLng || (Math.abs(userLat - newLat) > 0.0001 || Math.abs(userLng - newLng) > 0.0001);

                    userLat = newLat;
                    userLng = newLng;

                    if (hasMoved) {
                        console.log('User location updated:', userLat, userLng);
                        updateUserMarker(userLat, userLng);
                        updateLocationOnServer(userLat, userLng);
                        // Refresh nearby trees only if no special filter is active
                        if (currentDisplayMode === 'markers' && document.getElementById('dataType').value === 'all') {
                            fetchNearbyTrees();
                        }
                    }
                },
                (error) => {
                    console.warn('Geolocation tracking error:', error.message);
                    // Handle cases where user denies location permission
                    if(userLat === null) {
                        fetchNearbyTrees(); // Load default view
                    }
                },
                {
                    enableHighAccuracy: true,
                    maximumAge: 10000, // Don't use a cached position older than 10 seconds
                    timeout: 20000 // Give up after 20 seconds
                }
            );
        }

    // Start tracking as soon as the page is ready.
    startLiveLocationTracking();
      });

</script>


