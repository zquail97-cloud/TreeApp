    //Function to fetch and populate botanical species names of trees based on selected common species.
    async function updateBotanicalNames(commonNameDropdown, botanicalNameDropdown) {
    const selectedCommonName = commonNameDropdown.options[commonNameDropdown.selectedIndex].text;
    botanicalNameDropdown.innerHTML = '<option value="">Select a botanical name...</option>'; // Reset

    if (!selectedCommonName || selectedCommonName === 'Any Species') {
        botanicalNameDropdown.disabled = true;
        return;
    }

    try {
        const response = await fetch(`/api/species/botanical/${encodeURIComponent(selectedCommonName)}`);
        if (!response.ok) throw new Error('Failed to fetch botanical names.');
        
        const botanicalNames = await response.json();
        
        if (botanicalNames.length > 0) {
            botanicalNames.forEach(species => {
                const option = document.createElement('option');
                option.value = species.species_id;
                option.textContent = species.botanical_name;
                botanicalNameDropdown.appendChild(option);
            });
            botanicalNameDropdown.disabled = false;
        } else {
            botanicalNameDropdown.disabled = true;
        }
    } catch (error) {
        console.error("Error updating botanical names:", error);
        botanicalNameDropdown.disabled = true;
    }
}

