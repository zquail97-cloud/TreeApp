<!-- Homepage HTML/EJS that renders a map as a backdrop and displays login/signup forms for users
 Contains most of the Javascript functions that maniplate DOM and carry out transactions with the database. -->
<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>TreeApp – Explore Belfast’s Trees</title>
  <!-- Links to external spreadsheets: Leaflet for mapping, FontAwesome for icons & local stylesheet-->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
  <link rel="stylesheet" href="/css/style.css">
</head>

<body class="no-scroll">

  <script>
    
    const loggedInUser = <%- JSON.stringify(user || null) %>;
  </script>


  <!-- Sidebar Toggle Button -->
  <button id="sidebarToggle" class="sidebar-toggle">
    <i class="fa fa-bars"></i>
  </button>


  <!-- Collapsible Sidebar with options/user actions-->
  <div id="sidebar" class="sidebar">
    <h2>Tree Info & Options</h2>
    <p>Welcome to TreeApp 🌳</p>
    <p>Use the options below to filter or explore tree data.</p>


    <!-- Notifications section: displays nearby tree update requests -->
    <% if (typeof notifications !=='undefined' && notifications.length> 0) { %>
      <div class="alert-notification">
        <h3>Nearby Tree Update Requests</h3>
        <ul>
          <% notifications.forEach(note=> { %>
            <li class="notification-item" data-id="<%= note.notification_id %>">
              <%= note.message %><br>

                <!-- Zoom to Tree Button -->
                <button class="zoom-to-tree-btn" data-tree-id="<%= note.tree_id %>" title="Zoom to tree"
                  style="background: none; border: none; cursor: pointer;">
                  <i class="fas fa-map-pin"></i>
                </button>

                <!-- Mark as Read Button -->
                <button class="dismiss-btn" title="Mark as read"
                  style="background: none; border: none; cursor: pointer; margin-left: 10px;">
                  
                </button>
            </li>
            <% }) %>
        </ul>
      </div>
      <% } %>

        <hr>

        <!-- Tree data header -->
        <div class="collapsible-header">
          <h3>Explore Tree Data</h3>
          <button id="toggle-reporting-btn" class="sidebar-toggle-btn collapsed">
            <span id="toggle-reporting-icon">▼</span>
          </button>
        </div>


        <div id="reporting-controls" class="collapsed">

          <!-- Main display group -->
          <div class="control-group">
            <label for="displayMode">Display As:</label>
            <select id="displayMode">
              <option value="markers">Individual Trees (Markers)</option>
              <option value="heatmap">Density (Heatmap)</option>
            </select>
          </div>

          <!-- Choose data to be visualised-->
          <div class="control-group">
            <label for="dataType">Show Data For:</label>
            <select id="dataType">
              <option value="all">All Trees</option>
              <option value="health-good">Tree Health</option>
              <option value="verification">Verified Trees</option>
              <option value="updates">Trees with Pending Updates</option>
              <option value="data-quality">Data Quality / Confidence</option>
            </select>
          </div>

          <!-- Advanced filters -->
          <div class="control-group">
            <hr>
            <label for="filterSpecies">Filter by Species:</label>
            <select id="filterSpecies">
              <option value="">Any Species</option>
              <!-- Populated by JS -->
            </select>
          </div>

          <div class="control-group">
            <label for="filterCondition">Condition:</label>
            <select id="filterCondition">
              <option value="">Any Condition</option>
              <!-- Populated by JS -->
            </select>
          </div>

          <!-- Date Filters -->
          <div class="date-filter-group control-group">
            <label for="filterStartDate">Submitted After:</label>
            <input type="date" id="filterStartDate">
            <label for="filterEndDate">Submitted Before:</label>
            <input type="date" id="filterEndDate">
            <div class="date-quick-buttons">
              <button id="btn-last-7-days" class="sidebar-btn-date">Last 7 Days</button>
              <button id="btn-last-30-days" class="sidebar-btn-date">Last 30 Days</button>
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="button-group">
            <button id="apply-filters-btn" class="sidebar-btn-control">Apply Filters</button>
            <button id="clear-filters-btn" class="sidebar-btn-control">Clear Filters</button>
          </div>

          <hr>
          <div id="summary-stats-box">
          </div>
          <hr>
          <div class="control-group">
            <button id="open-chart-btn" class="sidebar-btn-control">View Chart</button>
          </div>

          <div class="list-controls">
            <label for="sort-list-by">Sort By:</label>
            <select id="sort-list-by">
              <option value="default">Default</option>
              <option value="species">Species (A-Z)</option>
              <option value="date-newest">Date Submitted (Newest)</option>
              <option value="condition-asc">Condition (Poor to Good)</option>
            </select>
          </div>
          <div id="interactive-list-container">
            <!-- The list of trees will be dynamically generated here by JavaScript -->
          </div>

        </div>


        <hr>
        <!-- User specific content: displays info of logged in user & displays submission form button, else a log in button -->
        <div id="notificationPanel" class="notification-panel">
          <h3>Your Account</h3>
          <ul id="notificationList"></ul>
        </div>
        <% if (user) { %>
          <p class="sidebar-user">Logged in as: <strong>
              <%= user.name %>
            </strong></p>
          <p class="sidebar-role">Role: <%= user.role %>
          </p>

          <hr>
          <a href="/notifications" id="openAccount" class="sidebar-account">📬 Account Management</a>

          <% if (user.role==='admin' ) { %>
            <a href="/admin/dashboard" class="sidebar-admin">Admin Dashboard</a>
            <% } %>

              <button id="openSubmitForm" class="sidebar-btn">Submit New Tree</button>
              <a href="/auth/logout" class="sidebar-logout">Logout</a>
              <% } else { %>
                <button id="openLoginForm" class="sidebar-btn">Log In</button>
                <% } %>

  </div>

  <!-- Top-left button to toggle form visibility  -->
  <div id="map-legend" class="map-legend">
    <button id="legend-toggle">
      <img src="/icons/marker-legend.png" alt="Toggle Legend" />
    </button>
    <div class="legend-content">
      <h4>Legend</h4>
      <div><img src="/icons/marker-green.png" /> This tree has been verified!</div>
      <div><img src="/icons/marker-orange.png" /> This tree is pending an update, cast your vote to verify it!</div>
      <div><img src="/icons/marker-blue.png" /> This tree hasn't been verified, suggest an update!</div>
    </div>
  </div>

  <!-- Tree Details Slide-Up Panel -->
  <div id="treeDetailsOverlay" class="details-overlay form-overlay">
    <div class="details-content">
      <button id="closeTreeDetailsBtn" class="details-close-btn">✕</button>
      <div id="treeDetailsInner"></div>
    </div>
  </div>

  <div id="comparePanel" class="compare-panel">
    <div class="compare-header">
      <h3>Suggested Update</h3>
      <button id="closeComparePanel">×</button>
    </div>
    <div id="compareContent" class="compare-content">
      <!-- Populated by JS -->
    </div>
  </div>

  <!-- Fullscreen map container -->
  <div id="map"></div>

  <!-- Overlay for login/signup form -->
  <div class="overlay" id="authOverlay">
    <div id="formContents">
      <!-- Close "X" Button -->
      <button id="closeOverlayBtn" title="Close" style="position: absolute; top: -10px; right: -30px; border: none; 
        background: none; font-size: 3.5rem; color: #444; cursor: pointer;">x</button>
      <h1>Welcome to TreeApp 🌳</h1>
      <p>Explore Belfast's trees and contribute your own observations.</p>


      <!-- Flash message for successful actions e.g. signing up or logging out -->
      <% if (typeof flash !=='undefined' && flash) { %>
        <div id="flashMessage" style="color: green; margin-bottom: 10px;">
          <%= flash %>
        </div>
        <% } %>

          <!-- Error messages e.g. invalid password -->
          <% if (typeof error !=='undefined' && error) { %>
            <div id="errorMessage" style="color: rgb(158, 40, 40); margin-bottom: 10px;">
              <%= error %>
            </div>
            <% } %>

              <!-- Conditional content: shows login/singup forms if the user is not already logged in -->
              <% if (!user) { %>
                <form id="authForm" method="POST" action="/auth/login">
                  <div id="usernameField" style="display: none;">
                    <input type="text" name="username" placeholder="Your Name">
                  </div>
                  <input type="email" name="email" placeholder="Email" required>
                  <input type="password" name="password" placeholder="Password" required>
                  <p style="text-align:center; margin-top: 1rem;">
                    <button type="submit" id="submitBtn">Login</button>
                    <a href="/auth/forgot-password" class="forgot-password-link">Forgot your password?</a>
                  </p>
                </form>

                <!-- Toggle link to switch between signing in and signing up -->
                <p id="togglePrompt">New here? <a href="#" id="toggleMode">Sign up</a></p>
                <% } else { %>
                  <p>Hello, <%= user.name %>!</p>
                  <% } %>
    </div>
  </div>



  <!-- Simplified user submission form -->
  <div id="submitOverlay">
    <div id="submitFormContents">
      <button class="overlay-close-btn" id="closeSubmitOverlayBtn">x</button>
      <h2>Submit a Tree</h2>

      <!-- Tree data submission form -->
      <form id="treeSubmitForm">
        <label for="speciesDropdown">Species</label>
        <select id="speciesDropdown" name="species_id" required></select>

        <label for="ageDropdown">Approximate Age</label>
        <select id="ageDropdown" name="age_id" required></select>

        <label for="conditionDropdown">Condition</label>
        <select id="conditionDropdown" name="condition_id" required></select>

        <input type="hidden" id="formLatitude" name="latitude" step="any" required>
        <input type="hidden" id="formLongitude" name="longitude" step="any" required>

        <button type="button" id="syncLocationBtn">📍 Use My Location</button>

        <label for="notes">Additional Notes (optional)</label>
        <textarea name="notes" id="notes" placeholder="Anything else you'd like to share?"></textarea>

        <!-- Expert Mode Toggle -->
        <div class="form-toggle">
        <input type="checkbox" id="submitExpertModeToggle">
        <label for="submitExpertModeToggle">Enable Expert Mode</label>
      </div>
      
       <!-- Expert Fields Container -->
      <div id="submitExpertFields" class="expert-fields-container" style="display: none;">
        <hr>
        <h4>Expert Details</h4>
        
        <label for="botanicalSpeciesDropdown">Species (Botanical Name)</label>
        <select id="botanicalSpeciesDropdown" name="botanical_species_id"></select>

        <label for="surroundDropdown">Surroundings</label>
        <select id="surroundDropdown" name="surround_id"></select>

        <label for="diameter">Diameter (cm)</label>
        <input type="number" id="diameter" name="diameter_cm" step="0.1" placeholder="e.g., 45.5">

        <label for="spreadRadius">Spread Radius (m)</label>
        <input type="number" id="spreadRadius" name="spread_radius_m" step="0.1" placeholder="e.g., 6.0">

        <label for="height">Tree Height (m)</label>
        <input type="number" id="height" name="tree_height_m" step="0.1" placeholder="e.g., 15.2">
      </div>

        <button type="submit">Submit Tree</button>
      </form>

      <!-- Image upload form -handled after tree submission -->
      <form id="imageUploadForm" enctype="multipart/form-data"> 
        <input type="hidden" id="imageTreeId" name="tree_id" value="">
        <input type="file" name="images" multiple required>
        <button type="submit">Upload Image(s)</button>
      </form>
    </div>
  </div>

  <!-- Form allowing users to suggest updates to existing trees -->
  <div id="suggestOverlay" class="form-overlay">
    <div id="suggestFormContents">
      <button class="overlay-close-btn" id="closeSuggestOverlayBtn">x</button>
      <h2>Suggest an Update</h2>

      <!-- Suggest update form -->
      <form id="suggestUpdateForm">
        <input type="hidden" id="suggestTreeId" name="tree_id">

        <label for="suggestSpecies">Species</label>
        <select id="suggestSpecies" name="species_id" required></select>

        <label for="suggestAge">Age</label>
        <select id="suggestAge" name="age_id" required></select>

        <label for="suggestCondition">Condition</label>
        <select id="suggestCondition" name="condition_id" required></select>

        <label for="suggestNotes">Notes (optional)</label>
        <textarea id="suggestNotes" name="notes" placeholder="Explain your suggestion..."></textarea>

        <!-- Expert Mode Toggle -->
        <div class="form-toggle">
            <input type="checkbox" id="suggestExpertModeToggle">
            <label for="suggestExpertModeToggle">Enable Expert Mode</label>
        </div>

        <!-- Expert Fields Container -->
        <div id="suggestExpertFields" class="expert-fields-container" style="display: none;">
            <hr>
            <h4>Expert Details</h4>
            
            <label for="suggestBotanicalSpecies">Species (Botanical Name)</label>
            <select id="suggestBotanicalSpecies" name="botanical_species_id"></select>

            <label for="suggestSurround">Surroundings</label>
            <select id="suggestSurround" name="surround_id"></select>

            <label for="suggestDiameter">Diameter (cm)</label>
            <input type="number" id="suggestDiameter" name="diameter_cm" step="0.1" placeholder="e.g., 45.5">

            <label for="suggestSpreadRadius">Spread Radius (m)</label>
            <input type="number" id="suggestSpreadRadius" name="spread_radius_m" step="0.1" placeholder="e.g., 6.0">

            <label for="suggestHeight">Tree Height (m)</label>
            <input type="number" id="suggestHeight" name="tree_height_m" step="0.1" placeholder="e.g., 15.2">
        </div>

        <button type="submit">Submit Suggestion</button>
      </form>

      <!-- Image upload form for update -->
      <form id="suggestImageUploadForm" enctype="multipart/form-data">
        <input type="hidden" id="suggestImageUpdateId" name="update_id" value="">
        <input type="file" name="images" multiple required>
        <button type="submit">Upload Image(s)</button>
      </form>

    </div>
  </div>

  </div>

  <!-- Loads Leaflet library for map view -->
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>



  <script>
    /*=============================================================================================*/
    // Global Variables & State Management
    /*=============================================================================================*/
     
    const map = L.map('map', {
      zoomControl: true, maxZoom: 19, minZoom: 13
    }).setView([54.597, -5.93], 16);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);
     
    let userLat = null;
    let userLng = null;
    let currentMarkers = [];
    let userCircle = null;
    let userIcon = null;
    let heatLayer = null;
    let currentDisplayMode = 'markers';
    let lastFetchedTrees = [];
    let chartsLoaded = false;
    let editingTreeId = null;

    google.charts.load('current', { 'packages': ['corechart'] });
    google.charts.setOnLoadCallback(() => { chartsLoaded = true; });

    /*=============================================================================================*/
    // Core Helper Functions
    /*=============================================================================================*/


    // --------------------------------------------------------------------------------- Map & Marker Helpers ---------------------------------------------------------------------------------

    // Function to update the user's location and 'paint' a circle around them to indiciate the range within trees will load
    function updateUserMarker(lat, lng) {
      if (userCircle) map.removeLayer(userCircle);
      if (userIcon) map.removeLayer(userIcon);
      userCircle = L.circle([lat, lng], { color: '#007BFF', fillColor: '#007BFF', fillOpacity: 0.1, radius: 300 }).addTo(map);
      userIcon = L.marker([lat, lng], { icon: L.icon({ iconUrl: '/icons/user-icon.png', iconSize: [100, 100], iconAnchor: [12, 12] }) }).addTo(map);
    }

    // Function to set the icons and their colours for trees based on their status; verified, unverified, awaiting update etc.
    function getMarkerIcon(isVerified, hasPendingUpdate) {
      let iconPath = '/icons/marker-blue.png';
      if (isVerified) iconPath = '/icons/marker-green.png';
      else if (hasPendingUpdate) iconPath = '/icons/marker-orange.png';
      return L.icon({ iconUrl: iconPath, iconSize: [30, 45], iconAnchor: [15, 42] });
    }

    // Function used by a reporting query which changes the colour of map tree markers based on their health.
    // Blue: default/fallback; Green: good; Fair: orange; Red: poor.
    // Sets their size. 
    function getHealthMarkerIcon(condition) {
      let iconUrl = '/icons/marker-blue.png';
      if (condition) {
        const lower = condition.toLowerCase();
        if (lower.includes('good') || lower.includes('excellent')) iconUrl = '/icons/marker-green.png';
        else if (lower.includes('fair')) iconUrl = '/icons/marker-orange.png';
        else if (lower.includes('poor') || lower.includes('dead')) iconUrl = '/icons/marker-red.png';
      }
      return L.icon({ iconUrl: iconUrl, iconSize: [30, 45], iconAnchor: [15, 42] });
    }

    // Function to fetch trees which have been submitted within thirty days prior.
    function isRecentlySubmitted(dateString) {
      if (!dateString) return false;
      const thirtyDaysAgo = new Date();
      thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);
      return new Date(dateString) > thirtyDaysAgo;
    }

    // Function similiar to getHealthMarkerIcon. Changes colour of tree markers for data quality search:
    // Verified Trees: green; Flagged Trees: red; Trees With Updates: Orange.
    // Sets their size.
    function getDataQualityMarkerIcon(tree) {
      if (tree.is_verified) return L.icon({ iconUrl: '/icons/marker-green.png', iconSize: [30, 45], iconAnchor: [15, 42] });
      if (tree.flag_type && tree.flag_type !== 'none') return L.icon({ iconUrl: '/icons/marker-red.png', iconSize: [30, 45], iconAnchor: [15, 42] });
      if (tree.has_pending_update || isRecentlySubmitted(tree.created_at)) return L.icon({ iconUrl: '/icons/marker-orange.png', iconSize: [30, 45], iconAnchor: [15, 42] });
      return L.icon({ iconUrl: '/icons/marker-grey.png', iconSize: [30, 45], iconAnchor: [15, 42] });
    }

    // Function to format distance which is then displaced in the mini portal within the sidebar.
    function formatDistance(km) {
      // Return an empty string if no distance was calculated (e.g., for non-location based searches)
      if (km === null || typeof km === 'undefined') {
        return '';
      }
      // If the distance is less than 1km, show it in meters for better readability
      if (km < 1) {
        const meters = Math.round(km * 1000);
        return `${meters}m away`;
      }
      // Otherwise, show it in kilometers with one decimal place
      return `${km.toFixed(1)}km away`;
    }

    // Function which can be called to clear all of the current markers on screen before rerendering the default map view. 
    function clearAllMarkers() {
      currentMarkers.forEach(marker => marker.remove());
      currentMarkers = [];
    }

    // Function to control scrolling through the image carousel of images uploaded alongside tree submissions and updates
    function scrollCarousel(direction) {
      const carousel = document.getElementById('imageCarousel');
      if (carousel) carousel.scrollBy({ left: direction * 300, behavior: 'smooth' });
    }


    // --------------------------------------------------------------------------------- Data & UI Helpers ---------------------------------------------------------------------------------

    // Function to determine the condition of trees, associating database values with numbers to be used in rendering functions.
    function getConditionScore(condition) {
      if (!condition) return 5; // Puts "N/A" or null values at the end

      const lowerCaseCondition = condition.toLowerCase();

      if (lowerCaseCondition.includes('dead') || lowerCaseCondition.includes('dying')) return 0;
      if (lowerCaseCondition.includes('poor')) return 1;
      if (lowerCaseCondition.includes('fair')) return 2;
      if (lowerCaseCondition.includes('good')) return 3;
      if (lowerCaseCondition.includes('excellent')) return 4;

      return 5; // Default for any other case
    }

    // Function which is executed on map load and anytime a search query is executed through searching parameters.
    // Provides a count of the total trees returned; those in good health (and as a %); 
    // a species count, and then provides the total number of trees, those in good health and the most common species.
    function updateSummaryStats(trees) {
      const container = document.getElementById('summary-stats-box');
      if (!container) return;

      if (trees.length === 0) {
        container.innerHTML = "<p>No results to summarize.</p>";
        return;
      }

      const goodHealthCount = trees.filter(t => ['Excellent', 'Good'].includes(t.condition_level)).length;
      const goodHealthPercent = Math.round((goodHealthCount / trees.length) * 100);

      const speciesCounts = trees.reduce((acc, t) => {
        if (t.common_name) acc[t.common_name] = (acc[t.common_name] || 0) + 1;
        return acc;
      }, {});
      const mostCommonSpecies = Object.keys(speciesCounts).reduce((a, b) => speciesCounts[a] > speciesCounts[b] ? a : b, 'N/A');

      container.innerHTML = `
        <div class="summary-stat"><strong>Showing:</strong> ${trees.length} trees</div>
        <div class="summary-stat"><strong>In Good Health:</strong> ${goodHealthPercent}%</div>
        <div class="summary-stat"><strong>Most Common:</strong> ${mostCommonSpecies}</div>
    `;
    }

    // Function used to draw a (Google) pie chart based on the information returned through searching queries (and on map load).
    // Renders the chart based on a breakdown of the species returned and the condition of those species.
    function drawConditionChart(trees, container) {
      // Stop if the container is invalid or the library isn't ready.
      if (!container || !google || !google.visualization) {
        console.error("Chart container is invalid or Google Charts is not ready.");
        return;
      }

      // Clear the container and stop if there's no data.
      if (!trees || trees.length === 0) {
        container.innerHTML = '<p style="text-align: center; color: #666;">No data available to display in chart.</p>';
        return;
      }

      const conditionCounts = trees.reduce((acc, t) => {
        const condition = t.condition_level || 'Unknown';
        acc[condition] = (acc[condition] || 0) + 1;
        return acc;
      }, {});

      const dataArray = [['Condition', 'Count']];
      for (const [condition, count] of Object.entries(conditionCounts)) {
        dataArray.push([condition, count]);
      }

      // Render chart
      const data = google.visualization.arrayToDataTable(dataArray);
      const options = {
        title: 'Tree Condition Breakdown',
        pieHole: 0.4,
        fontName: 'DM Sans',
        fontSize: 25
      };

      const chart = new google.visualization.PieChart(container);
      chart.draw(data, options);
    }

    // Function to add markers thematically based on reporting parameters
    function addMarkersThematically(trees, colorMode) {
      clearAllMarkers();
      const listContainer = document.getElementById('interactive-list-container');
      const sortBy = document.getElementById('sort-list-by').value;

      listContainer.innerHTML = `<h3>Showing ${trees.length} Results</h3>`;

      let sortedTrees = [...trees];
      if (sortBy === 'species') { sortedTrees.sort((a, b) => (a.common_name || '').localeCompare(b.common_name || '')); }
      if (sortBy === 'date-newest') { sortedTrees.sort((a, b) => new Date(b.created_at) - new Date(a.created_at)); }
      if (sortBy === 'condition-asc') { sortedTrees.sort((a, b) => getConditionScore(a.condition_level) - getConditionScore(b.condition_level)); }

      const highlightListItem = (item) => {
        document.querySelectorAll('.tree-list-item.active').forEach(i => i.classList.remove('active'));
        if (item) item.classList.add('active');
      };

      // Loop now uses the 'sortedTrees' array.
      sortedTrees.forEach(tree => {
        let icon;
        if (colorMode === 'data-quality') icon = getDataQualityMarkerIcon(tree);
        else if (colorMode.startsWith('health')) icon = getHealthMarkerIcon(tree.condition_level);
        else if (colorMode === 'updates') icon = L.icon({ iconUrl: '/icons/marker-orange.png' });
        else icon = getMarkerIcon(tree.is_verified, tree.has_pending_update);

        const marker = L.marker([tree.latitude, tree.longitude], { icon: icon, treeId: tree.tree_id });
        marker.bindPopup(`<strong>${tree.common_name || 'Unknown'}</strong><br><button class="view-details-btn" data-tree-id="${tree.tree_id}">Details</button>`);
        marker.addTo(map);
        currentMarkers.push(marker);

        const listItem = document.createElement('div');
        listItem.className = 'tree-list-item';
        listItem.innerHTML = `
            <div>
                <strong>${tree.common_name || 'Unknown'}</strong>
                <br>
                <small>Status: ${tree.is_verified ? 'Verified' : 'Pending'} | Condition: ${tree.condition_level || 'N/A'}</small>
            </div>
            <span class="distance-display">${formatDistance(tree.distance)}</span>
        `;

        listItem.addEventListener('click', () => {
          map.setView([tree.latitude, tree.longitude], 18);
          marker.openPopup();
          highlightListItem(listItem);
        });

        marker.on('click', () => {
          highlightListItem(listItem);
          listItem.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });
        listContainer.appendChild(listItem);
      });
    }

    // Function to dynamically populate the dropdown elements that are used for dynamic reporting.
    function populateDropdown(selectId, apiEndpoint, valueKey, textKey, defaultOptionText = 'Any') {
      const dropdown = document.getElementById(selectId);
      if (!dropdown) {
        console.error(`Dropdown element with ID '${selectId}' not found.`);
        return;
      }
      fetch(apiEndpoint).then(res => res.json()).then(data => {
        dropdown.innerHTML = `<option value="">${defaultOptionText}</option>`;
        data.forEach(item => {
          const option = document.createElement('option');
          option.value = item[valueKey];
          option.textContent = item[textKey];
          dropdown.appendChild(option);
        });
      }).catch(err => console.error(`Error loading ${apiEndpoint}:`, err));
    }

