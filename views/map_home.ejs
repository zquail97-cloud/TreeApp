    // Function which fetches the location of trees nearby to the user, using these locations to plot markers on the map.
    function fetchNearbyTrees() {
      if (!userLat || !userLng) return;
      fetch(`/api/trees/nearby?latitude=${userLat}&longitude=${userLng}`)
        .then(res => res.json())
        .then(trees => {
          lastFetchedTrees = trees;
          updateSummaryStats(trees);
          addMarkersThematically(trees, 'status');
        })
        .catch(err => console.error("Error fetching nearby trees:", err));
    }

    // Function that calls update-location from api.js, updates the user's last known location in the database by storing their latitide & longitude (viaa browser).
    function updateLocationOnServer(lat, lng) {
      fetch('/api/update-location', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ latitude: lat, longitude: lng }) })
        .catch(err => console.error('Error updating server location:', err));
    }

    // Fetches known tree information from the database and then renders this information in tree card popups and overlays (submission and suggestion).
    function fetchAndShowTreeDetails(treeId) {
  Promise.all([
    fetch(`/api/trees/${treeId}`).then(res => {
      if (!res.ok) throw new Error(`Server responded with ${res.status}`);
      return res.json();
    }),
    fetch(`/api/trees/${treeId}/images`).then(res => {
      if (!res.ok) throw new Error(`Server responded with ${res.status}`);
      return res.json();
    })
  ])
  .then(([tree, images]) => {
    if (tree.error) throw new Error(tree.error);
    const overlay = document.getElementById('treeDetailsOverlay');
    const content = document.getElementById('treeDetailsInner');

    function safeField(label, value, unit = '') {
      return value != null && value !== 'null' && value !== ''
        ? `<p><strong>${label}:</strong> ${value}${unit}</p>`
        : '';
    }

    let detailsHTML = `
        <h2>${tree.common_name || 'Unknown Species'}</h2>
        <p class="botanical-name-display">${tree.botanical_name || ''}</p>
      `;

    detailsHTML += safeField('Age', tree.age_desc);
    detailsHTML += safeField('Condition', tree.condition_level);
    detailsHTML += safeField('Surroundings', tree.surround_type);
    detailsHTML += safeField('Height', tree.tree_height_m, 'm');
    detailsHTML += safeField('Spread Radius', tree.spread_radius_m, 'm');
    detailsHTML += safeField('Diameter', tree.diameter_cm, 'cm');
    detailsHTML += safeField('Notes', tree.notes);

    if (images.length > 0) {
  detailsHTML += `
    <p><strong>Images:</strong></p>
    <div class="tree-popup-image-container">
      ${images.map(img => `
        <img 
          src="${img.image_url}" 
          class="tree-popup-thumbnail" 
          alt="Tree image. Click to enlarge." 
          title="Click to enlarge. Taken with ${img.camera_make || 'Unknown Camera'}"
          data-full-src="${img.image_url}"
        >
      `).join('')}
    </div>
  `;
}

    if (loggedInUser && loggedInUser.role === 'user') {
      detailsHTML += `<button class="suggest-update-btn" data-tree-id="${tree.tree_id}">Suggest Update</button>`;
    }
    if (tree.has_pending_update === 1) {
      detailsHTML += `<button class="compare-update-btn" data-tree-id="${tree.tree_id}">Compare Update</button>`;
    }

    content.innerHTML = detailsHTML;
    overlay.classList.add('show');     

  })
  .catch(err => {
    console.error('Error fetching tree details or images:', err);
  });
}


    // Function to open the compare update panel. Fetches known (current) data saved in the database vs pending (staged) data, rendering them in a popup overlay. 
    // Allows users to cast up and downvotes on suggested update, which is used to execute AI decision making. 
    function openCompareUpdatePanel(treeId) {
  fetch(`/api/trees/${treeId}/compare`)
    .then(res => res.json())
    .then(({ current, pending }) => {
      const panel = document.getElementById('comparePanel');
      const content = document.getElementById('compareContent');

      // Helper to handle potentially different species structures
      const getSpeciesDisplay = (record) => {
        if (!record) return '—';
        return `${record.common_name || ''}<br><small>${record.botanical_name || ''}</small>`;
      };
      
      const compareField = (label, currentVal, suggestedVal) => `
          <div class="compare-row">
            <div class="compare-label">${label}</div>
            <div class="compare-current">${currentVal || '—'}</div>
            <div class="compare-arrow">→</div>
            <div class="compare-suggested">${suggestedVal || '—'}</div>
          </div>
        `;

      let html = '<h3>Suggested Update</h3>';
      html += compareField('Species', getSpeciesDisplay(current), getSpeciesDisplay(pending));
      html += compareField('Age', current.age_desc, pending.age_desc);
      html += compareField('Condition', current.condition_level, pending.condition_level);
      html += compareField('Surroundings', current.surround_type, pending.surround_type);
      html += compareField('Height (m)', current.tree_height_m, pending.tree_height_m);
      html += compareField('Spread (m)', current.spread_radius_m, pending.spread_radius_m);
      html += compareField('Diameter (cm)', current.diameter_cm, pending.diameter_cm);
      html += compareField('Notes', current.notes, pending.notes);

      html += `
          <div class="vote-buttons">
            <button class="vote-btn upvote" data-update-id="${pending.update_id}" data-vote="up">👍 Upvote</button>
            <button class="vote-btn downvote" data-update-id="${pending.update_id}" data-vote="down">👎 Downvote</button>
          </div>
        `;

      content.innerHTML = html;
      panel.classList.add('show');
    })
    .catch(err => {
      console.error('Failed to load comparison:', err);
    });
}

    // Function to fetch unread notifications for user's, to be displayed in the sidebar.
    async function loadNotifications() {
          const res = await fetch('/api/notifications');
          const data = await res.json();

          const list = document.getElementById('notificationList');
          list.innerHTML = '';

          data.notifications.forEach(note => {
            const li = document.createElement('li');
            li.textContent = note.message;
            li.classList.toggle('unread', note.is_read === 0);
            li.addEventListener('click', () => markNotificationAsRead(note.notification_id));
            list.appendChild(li);
          });
        }

    async function markNotificationAsRead(id) {
          await fetch(`/api/notifications/${id}/read`, { method: 'POST' });
          loadNotifications(); // Refresh list
        }

